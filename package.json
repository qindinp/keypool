{
  "name": "keypool",
  "version": "0.4.0",
  "description": "OpenAI API Key Pool Proxy — 多 Key 聚合代理，零依赖",
  "main": "bin/server.mjs",
  "type": "module",
  "scripts": {
    "start": "node bin/server.mjs",
    "dev": "node --watch bin/server.mjs",
    "app": "node bin/app.mjs",
    "app:bg:start": "node scripts/app-bg.mjs start",
    "app:bg:stop": "node scripts/app-bg.mjs stop",
    "app:bg:status": "node scripts/app-bg.mjs status",
    "manager": "node bin/manager.mjs",
    "manager:once": "node bin/manager.mjs --once",
    "manager:status": "node bin/manager.mjs --status",
    "manager:deploy": "node bin/manager.mjs --deploy",
    "relay": "node bin/relay.mjs",
    "relay:dev": "node --watch bin/relay.mjs",
    "test:relay": "node scripts/test-relay.mjs",
    "ws": "node bin/ws-client.mjs",
    "probe": "node scripts/ws-probe.mjs"
  },
  "keywords": ["openai", "proxy", "key-pool", "llm"],
  "license": "MIT"
}
